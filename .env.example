# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hhs_patient_portal
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSLMODE=prefer

# Application Configuration
PORT=3000
NODE_ENV=development

# Security - Generate strong random strings for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_session_secret_change_in_production
JWT_SECRET=your_jwt_secret_change_in_production

# HIPAA Compliance Settings
SESSION_TIMEOUT_MINUTES=15
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
PASSWORD_EXPIRY_DAYS=90
RATELIMIT_STORAGE_URI=memory://
DB_POOL_MIN_CONN=1
DB_POOL_MAX_CONN=10
DB_CONNECT_TIMEOUT=10
DB_APPLICATION_NAME=hhs-patient-portal-api

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173

# GitHub integration (optional, for doctor-side feature request submissions)
# Create a fine-grained token with Issues: Read and Write for the target repo.
GITHUB_TOKEN=
GITHUB_REPO=nhudson99/HHS-patient-portal
GITHUB_FEATURE_REQUEST_LABELS=feature-request,copilot-agent

# Kiosk unregistered check-in alert email
# Defaults to nathan@hudsonitconsulting.com if CHECKIN_ALERT_EMAIL is not set.
CHECKIN_ALERT_EMAIL=nathan@hudsonitconsulting.com

# Recommended: Microsoft Graph API alert sender (client credentials)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_USER=

# Legacy fallback: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Document storage
# local: stores files under DOCUMENTS_LOCAL_DIR (recommended for local dev)
# azure_blob: stores files in Azure Blob container (recommended for production)
DOCUMENTS_STORAGE_BACKEND=local
DOCUMENTS_LOCAL_DIR=/tmp/hhs-documents
DOCUMENTS_BLOB_CONTAINER=hhs-documents
# Option A: endpoint + credential (account key or SAS token)
DOCUMENTS_BLOB_ENDPOINT=
DOCUMENTS_BLOB_CREDENTIAL=
# Option B: full Azure Blob connection string
DOCUMENTS_BLOB_CONNECTION_STRING=

# Kiosk unregistered check-in alert email
# Defaults to nathan@hudsonitconsulting.com if CHECKIN_ALERT_EMAIL is not set.
CHECKIN_ALERT_EMAIL=nathan@hudsonitconsulting.com

# Recommended: Microsoft Graph API alert sender (client credentials)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_USER=

# Legacy fallback: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Azure AD / Entra SSO
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
VITE_AZURE_REDIRECT_URI=

# Azure production deploy/runtime defaults
FORCE_HTTPS=true
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=180

# Audit Log Retention (days)
AUDIT_LOG_RETENTION_DAYS=2555
